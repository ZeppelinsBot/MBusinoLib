#include <MBusinoLib.h>   // Library for decode M-Bus
#include <ArduinoJson.h>  // ArduinoJson Version 7 is used to transfere the Data

#define START_ADDRESS 0x13  // Start address for decoding
unsigned long timerMbus = 5000;

void setup() {
  Serial.begin(9600);
}

void loop() {
  if (millis() - timerMbus > 5000) {
    timerMbus = millis();
    byte mbus_data[] = {0x68,0xC1,0xC1,0x68,0x08,0x00,0x72,0x09,0x34,0x75,0x73,0xC5,0x14,0x00,0x0D,0x43,0x00,0x00,0x00,0x04,0x78,0x41,0x63,0x65,0x04,0x04,0x06,0xAA,0x29,0x00,0x00,0x04,0x13,0x40,0xA1,0x75,0x00,0x04,0x2B,0x00,0x00,0x00,0x00,0x14,0x2B,0x3C,0xF3,0x00,0x00,0x04,0x3B,0x48,0x06,0x00,0x00,0x14,0x3B,0x4E,0x0E,0x00,0x00,0x02,0x5B,0x19,0x00,0x02,0x5F,0x19,0x00,0x02,0x61,0xFA,0xFF,0x02,0x23,0xAC,0x08,0x04,0x6D,0x03,0x2A,0xF1,0x2A,0x44,0x06,0x92,0x0C,0x00,0x00,0x44,0x13,0x2D,0x9B,0x1C,0x00,0x42,0x6C,0xDF,0x2C,0x01,0xFD,0x17,0x00,0x03,0xFD,0x0C,0x05,0x00,0x00,0x84,0x10,0x06,0x1A,0x00,0x00,0x00,0xC4,0x10,0x06,0x05,0x00,0x00,0x00,0x84,0x20,0x06,0x00,0x00,0x00,0x00,0xC4,0x20,0x06,0x00,0x00,0x00,0x00,0x84,0x30,0x06,0x00,0x00,0x00,0x00,0xC4,0x30,0x06,0x00,0x00,0x00,0x00,0x84,0x40,0x13,0x00,0x00,0x00,0x00,0xC4,0x40,0x13,0x00,0x00,0x00,0x00,0x84,0x80,0x40,0x13,0x00,0x00,0x00,0x00,0xC4,0x80,0x40,0x13,0x00,0x00,0x00,0x00,0x84,0xC0,0x40,0x13,0x00,0x00,0x00,0x00,0xC4,0xC0,0x40,0x13,0x00,0x00,0x00,0x00,0x75,0x16};
    //byte mbus_data[] = {0x68,0xC4,0xC4,0x68,0x08,0x14,0x72,0x72,0x91,0x07,0x29,0x47,0x5F,0x03,0x16,0xC2,0x00,0x00,0x00,0x04,0x13,0x8B,0x01,0x00,0x00,0x04,0x6D,0x1E,0x14,0x4D,0x32,0x42,0x6C,0x00,0x00,0x44,0x13,0x00,0x00,0x00,0x00,0x42,0xEC,0x7E,0x57,0x36,0x0C,0x78,0x24,0x33,0x05,0x61,0x82,0x01,0x6C,0x3E,0x36,0x84,0x01,0x13,0x00,0x00,0x00,0x00,0xC2,0x01,0x6C,0x3F,0x37,0xC4,0x01,0x13,0x00,0x00,0x00,0x00,0x82,0x02,0x6C,0x3F,0x38,0x84,0x02,0x13,0x00,0x00,0x00,0x00,0xC2,0x02,0x6C,0x3E,0x39,0xC4,0x02,0x13,0x00,0x00,0x00,0x00,0x82,0x03,0x6C,0x3F,0x3A,0x84,0x03,0x13,0x00,0x00,0x00,0x00,0xC2,0x03,0x6C,0x3E,0x3B,0xC4,0x03,0x13,0x00,0x00,0x00,0x00,0x82,0x04,0x6C,0x3F,0x3C,0x84,0x04,0x13,0xA9,0x00,0x00,0x00,0xC2,0x04,0x6C,0x5F,0x31,0xC4,0x04,0x13,0x56,0x01,0x00,0x00,0x82,0x05,0x6C,0x00,0x00,0x84,0x05,0x13,0x00,0x00,0x00,0x00,0xC2,0x05,0x6C,0x00,0x00,0xC4,0x05,0x13,0x00,0x00,0x00,0x00,0x82,0x06,0x6C,0x00,0x00,0x84,0x06,0x13,0x00,0x00,0x00,0x00,0xC2,0x06,0x6C,0x00,0x00,0xC4,0x06,0x13,0x00,0x00,0x00,0x00,0x0F,0x01,0x00,0x00,0xFB,0x16};

    int packet_size = sizeof(mbus_data);

    // --- Unified JsonDocument ---
    JsonDocument doc;
    MBusinoLib decode;

    // 1. Decode Header into nested object "header"
    JsonObject headerObj = doc["header"].to<JsonObject>();
    bool headerOk = decode.decodeHeader(mbus_data, packet_size, headerObj);

    // 2. Decode Records into nested array "records"
    JsonArray recordsArr = doc["records"].to<JsonArray>();
    uint8_t fields = decode.decodeRecords(&mbus_data[START_ADDRESS], packet_size - START_ADDRESS - 2, recordsArr);

    // --- Serial Output START ---
    Serial.println();
    Serial.println();
    Serial.println("###################### new message ###################### ");
    Serial.println();
    Serial.print("error = ");
    Serial.println(decode.getError());
    Serial.print("jsonstring = ");
    serializeJson(doc, Serial);
    Serial.println();
    Serial.println();

    // --- M-Bus Header Data Output ---
    if (headerOk) {
      Serial.println("--- M-Bus Header Data (Individual Fields) ---");
      Serial.println();
      Serial.print("Adress(dec):    ");
      Serial.println(headerObj["a_field"].as<int>());
      Serial.print("ID:             ");
      Serial.println(headerObj["id"].as<const char*>());
      Serial.print("Manufacturer:   ");
      Serial.println(headerObj["manufacturer"].as<const char*>());
      Serial.print("Medium:         ");
      Serial.println(headerObj["medium"].as<const char*>());
      Serial.print("Status Byte:    ");
      Serial.print("0x");
      Serial.println(headerObj["status"].as<int>(), HEX);
      Serial.print("Version:        ");
      Serial.println(headerObj["version"].as<int>());
      Serial.print("Access Counter: ");
      Serial.println(headerObj["access_counter"].as<int>());

      // Status details
      Serial.print("Battery Low:    ");
      Serial.println(headerObj["status_details"]["battery_low"].as<bool>() ? "YES" : "NO");
      Serial.print("Temporary Err:  ");
      Serial.println(headerObj["status_details"]["temporary_error"].as<bool>() ? "YES" : "NO");
      Serial.print("Permanent Err:  ");
      Serial.println(headerObj["status_details"]["permanent_error"].as<bool>() ? "YES" : "NO");
    }
    Serial.println();
    Serial.println("--- M-Bus Records ---");
    Serial.println();

    // --- M-Bus Record Output ---
    for (uint8_t i = 0; i < fields; i++) {
      const char* name = recordsArr[i]["name"];
      const char* units = recordsArr[i]["units"];
      double value = recordsArr[i]["value_scaled"].as<double>();
      const char* valueString = recordsArr[i]["value_string"];

      // Variable string value
      if (valueString != NULL) {
        Serial.print(i + 1); Serial.print("_vs_"); Serial.print(name); Serial.print(" = "); Serial.println(valueString);
      }

      // Numeric value
      Serial.print(i + 1); Serial.print("_"); Serial.print(name); Serial.print(" = ");

      // Fix for "ovf" on large numbers like time points
      if (value > 1000000000.0) {
        Serial.println((int64_t)value);
      } else {
        Serial.println(value, 3);
      }

      // Unit
      if (units != NULL) {
        Serial.print(i + 1); Serial.print("_"); Serial.print(name); Serial.print("_unit = "); Serial.println(units);
      }
    }
    Serial.println("###################### end of message ###################### ");
  }
}

